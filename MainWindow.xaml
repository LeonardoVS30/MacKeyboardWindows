<Window x:Class="MacKeyboardWindows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Mac Keyboard for Windows"
        Icon="AppIcon.ico"
        SizeToContent="Manual"
        Width="1100" Height="350"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize" 
        Topmost="True"
        Loaded="MainWindow_Loaded"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <!-- CONFIGURACIÓN DE REDIMENSIONADO NATIVO (WINDOW CHROME) -->
    <WindowChrome.WindowChrome>
        <WindowChrome 
            ResizeBorderThickness="10" 
            CaptionHeight="0" 
            CornerRadius="12" 
            GlassFrameThickness="0"/>
            
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ANIMACIÓN DEL MENÚ HAMBURGUESA -->
        <ControlTemplate x:Key="HamburgerMenuTemplate" TargetType="ToggleButton">
            <Border Background="Transparent" Width="30" Height="30" CornerRadius="15">
                <Grid Width="16" Height="14" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Rectangle x:Name="TopLine" Height="2" Width="16" VerticalAlignment="Top" Fill="{DynamicResource KeyForegroundColor}" RadiusX="1" RadiusY="1" RenderTransformOrigin="0.5,0.5">
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="0"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>
                    <Rectangle x:Name="MiddleLine" Height="2" Width="16" VerticalAlignment="Center" Fill="{DynamicResource KeyForegroundColor}" RadiusX="1" RadiusY="1" Opacity="1"/>
                    <Rectangle x:Name="BottomLine" Height="2" Width="16" VerticalAlignment="Bottom" Fill="{DynamicResource KeyForegroundColor}" RadiusX="1" RadiusY="1" RenderTransformOrigin="0.5,0.5">
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="0"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="TopLine" Property="RenderTransform">
                        <Setter.Value>
                            <TransformGroup>
                                <TranslateTransform Y="6"/>
                                <RotateTransform Angle="45"/>
                            </TransformGroup>
                        </Setter.Value>
                    </Setter>
                    <Setter TargetName="MiddleLine" Property="Opacity" Value="0"/>
                    <Setter TargetName="BottomLine" Property="RenderTransform">
                        <Setter.Value>
                            <TransformGroup>
                                <TranslateTransform Y="-6"/>
                                <RotateTransform Angle="-45"/>
                            </TransformGroup>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>

    <!-- EL FONDO #01000000 PERMITE QUE EL MOUSE "AGARRE" LOS BORDES TRANSPARENTES -->
    <Grid Background="#01000000">

        <!-- EL VIEWBOX ESCALA EL TECLADO COMPLETO SEGÚN EL TAMAÑO DE LA VENTANA -->
        <Viewbox Stretch="Uniform" VerticalAlignment="Top">
            <!-- Usamos un Grid contenedor para que el Border y la Transición ocupen el mismo espacio -->
            <Grid Width="1100" Height="350">

                <!-- Tu teclado real -->
                <Border Name="MainBorder" 
                    Width="1100" Height="350" 
                    VerticalAlignment="Top" 
                    HorizontalAlignment="Left"
                    Background="{DynamicResource WindowBackgroundColor}" 
                    CornerRadius="12" 
                    BorderBrush="{DynamicResource WindowBorderColor}" 
                    BorderThickness="1">
                    <Grid>
                        <!-- ... contenido del teclado ... -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="10,4,10,0" VerticalAlignment="Top" Height="40">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- HAMBURGER MENU -->
                            <ToggleButton x:Name="MenuToggleButton" 
                                          Grid.Column="0" 
                                          Template="{StaticResource HamburgerMenuTemplate}"
                                          VerticalAlignment="Center"
                                          Click="MenuToggleButton_Click">
                                <ToggleButton.ContextMenu>
                                    <ContextMenu Style="{StaticResource AppContextMenuStyle}" Closed="MainMenu_Closed">
                                        <!-- THEMES -->
                                        <MenuItem Header="Theme">
                                            <MenuItem Header="System (Auto)" Tag="System" Click="Theme_Click"/>
                                            <MenuItem Header="Dark" Tag="Dark" Click="Theme_Click"/>
                                            <MenuItem Header="Light" Tag="Light" Click="Theme_Click"/>
                                            <MenuItem Header="Liquid Glass" Tag="LiquidGlass" Click="Theme_Click"/>
                                        </MenuItem>
                                        <!-- LAYOUTS -->
                                        <MenuItem Header="Layout">
                                            <MenuItem Header="Español (ES)" Tag="ES" Click="Layout_Click"/>
                                            <MenuItem Header="English (US)" Tag="US" Click="Layout_Click"/>
                                        </MenuItem>
                                        <!-- PIANO SCALE -->
                                        <MenuItem Header="Piano Scale">
                                            <MenuItem Header="Major" >
                                                <MenuItem Header="C Major (Do Mayor)" Tag="C_Major" Click="Scale_Click"/>
                                                <MenuItem Header="D Major (Re Mayor)" Tag="D_Major" Click="Scale_Click"/>
                                                <MenuItem Header="E Major (Mi Mayor)" Tag="E_Major" Click="Scale_Click"/>
                                                <MenuItem Header="F Major (Fa Mayor)" Tag="F_Major" Click="Scale_Click"/>
                                                <MenuItem Header="G Major (Sol Mayor)" Tag="G_Major" Click="Scale_Click"/>
                                                <MenuItem Header="A Major (La Mayor)" Tag="A_Major" Click="Scale_Click"/>
                                                <MenuItem Header="B Major (Si Mayor)" Tag="B_Major" Click="Scale_Click"/>
                                            </MenuItem>
                                            <MenuItem Header="Minor">
                                                <MenuItem Header="C Minor (Do Menor)" Tag="C_Minor" Click="Scale_Click"/>
                                                <MenuItem Header="D Minor (Re Menor)" Tag="D_Minor" Click="Scale_Click"/>
                                                <MenuItem Header="E Minor (Mi Menor)" Tag="E_Minor" Click="Scale_Click"/>
                                                <MenuItem Header="F Minor (Fa Menor)" Tag="F_Minor" Click="Scale_Click"/>
                                                <MenuItem Header="G Minor (Sol Menor)" Tag="G_Minor" Click="Scale_Click"/>
                                                <MenuItem Header="A Minor (La Menor)" Tag="A_Minor" Click="Scale_Click"/>
                                                <MenuItem Header="B Minor (Si Menor)" Tag="B_Minor" Click="Scale_Click"/>
                                            </MenuItem>
                                        </MenuItem>
                                        <Separator Style="{StaticResource AppMenuSeparatorStyle}"/>
                                        <!-- ZOOM -->
                                        <MenuItem Header="Zoom">
                                            <MenuItem Header="50%" Tag="0.5" Click="Zoom_Click"/>
                                            <MenuItem Header="75%" Tag="0.75" Click="Zoom_Click"/>
                                            <MenuItem Header="100%" Tag="1.0" Click="Zoom_Click"/>
                                            <MenuItem Header="125%" Tag="1.25" Click="Zoom_Click"/>
                                            <MenuItem Header="150%" Tag="1.5" Click="Zoom_Click"/>
                                        </MenuItem>
                                        <!-- OPACITY -->
                                        <MenuItem Header="Opacity">
                                            <MenuItem Header="100%" Tag="1.0" Click="Opacity_Click"/>
                                            <MenuItem Header="80%" Tag="0.8" Click="Opacity_Click"/>
                                            <MenuItem Header="60%" Tag="0.6" Click="Opacity_Click"/>
                                            <MenuItem Header="40%" Tag="0.4" Click="Opacity_Click"/>
                                        </MenuItem>
                                        <Separator Style="{StaticResource AppMenuSeparatorStyle}"/>
                                        <!-- TOGGLES -->
                                        <MenuItem x:Name="SoundMenuItem" Header="Sound" IsCheckable="True" IsChecked="True" Click="SoundToggle_Click"/>
                                        <MenuItem x:Name="StartupMenuItem" Header="Start with Windows" IsCheckable="True" Click="StartupToggle_Click"/>
                                        <Separator Style="{StaticResource AppMenuSeparatorStyle}"/>
                                        <MenuItem Header="Close to Tray" Click="CloseMenuItem_Click"/>
                                    </ContextMenu>
                                </ToggleButton.ContextMenu>
                            </ToggleButton>

                            <!-- MODE TOGGLE SWITCH -->
                            <Border Grid.Column="1" Style="{StaticResource ModeToggleContainerStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="KeyboardModeToggle" 
                                                 Style="{StaticResource ModeToggleButtonStyle}" 
                                                 GroupName="ModeToggle" 
                                                 IsChecked="True" 
                                                 Checked="KeyboardModeToggle_Checked">
                                        <Path Data="{StaticResource IconKeyboard}" 
                                              Fill="{DynamicResource KeyForegroundColor}" 
                                              Stretch="Uniform" Width="16" Height="16"/>
                                    </RadioButton>
                                    <RadioButton x:Name="PianoModeToggle" 
                                                 Style="{StaticResource ModeToggleButtonStyle}" 
                                                 GroupName="ModeToggle" 
                                                 Checked="PianoModeToggle_Checked">
                                        <Path Data="{StaticResource IconPiano}" 
                                              Fill="{DynamicResource KeyForegroundColor}" 
                                              Stretch="Uniform" Width="16" Height="16"/>
                                    </RadioButton>
                                </StackPanel>
                            </Border>

                            <!-- WINDOW BUTTONS -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource NeumorphicHeaderButtonStyle}" MouseLeftButtonDown="MinimizeButton_Click">
                                    <Path Data="{StaticResource IconWindowMinimize}" Style="{StaticResource NeumorphicHeaderIconStyle}"/>
                                </Border>
                                <Border Style="{StaticResource NeumorphicHeaderButtonStyle}" MouseLeftButtonDown="CloseButton_Click">
                                    <Path Data="{StaticResource IconWindowClose}" Style="{StaticResource NeumorphicHeaderIconStyle}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                        <Grid x:Name="KeyboardContainer" Grid.Row="1" Margin="5,0,5,10" />
                        <Grid x:Name="PianoContainer" Grid.Row="1" Margin="5,0,5,10" Visibility="Collapsed" />

                    </Grid>
                </Border>

                <!-- CAPA DE TRANSICIÓN: Ahora está dentro del Viewbox -->
                <!-- Al estar aquí, ya no necesita el LayoutTransform individual -->
                <Grid x:Name="TransitionOverlay" Visibility="Collapsed" IsHitTestVisible="False">
                    <Rectangle x:Name="TransitionVisual" 
                           Width="1100" Height="350" 
                           RadiusX="12" RadiusY="12"/>

                    <Border x:Name="TransitionGlassWave" Width="120" HorizontalAlignment="Left" VerticalAlignment="Stretch" Background="#40FFFFFF">
                        <Border.Effect>
                            <BlurEffect Radius="40"/>
                        </Border.Effect>
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="GlassWaveTranslate" X="-150"/>
                        </Border.RenderTransform>
                    </Border>
                </Grid>
            </Grid>
        </Viewbox>

        <!-- ICONO DE BANDEJA DE ENTRADA -->
        <tb:TaskbarIcon x:Name="MyNotifyIcon"
                        IconSource="/AppIcon.ico"
                        ToolTipText="Mac Keyboard for Windows"
                        TrayMouseDoubleClick="NotifyIcon_DoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu Style="{StaticResource AppContextMenuStyle}">
                    <MenuItem Header="Show Keyboard" FontWeight="Bold" Click="NotifyIcon_Open_Click"/>
                    <Separator Style="{StaticResource AppMenuSeparatorStyle}"/>
                    <MenuItem Header="Exit" Click="NotifyIcon_Exit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>